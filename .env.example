# Environment variables for LinkedIn Scraper Web App
# Copy this to .env and update the values

# Flask secret key — change this to a random string in production
FLASK_SECRET_KEY=change-me-to-a-random-secret-string

# Debug mode (true/false) — set to false in production
FLASK_DEBUG=false

# Port to run the server on
PORT=5000

# Scraper timeout per request (Max seconds)
SCRAPER_TIMEOUT=45

# Maximum retry attempts per request
MAX_RETRIES=3
